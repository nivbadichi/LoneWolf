{
  "info": {
    "name": "LoneWolf API",
    "_postman_id": "lonewolf-api-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "eventId", "value": "" },
    { "key": "reportId", "value": "" },
    { "key": "notificationId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alex Wilson\",\n  \"email\": \"alex@test.com\",\n  \"password\": \"mypassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) { pm.collectionVariables.set(\"token\", data.token); }",
                  "if (data.user && data.user.id) { pm.collectionVariables.set(\"userId\", data.user.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alex@test.com\",\n  \"password\": \"mypassword123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/users/me", "host": ["{{baseUrl}}"], "path": ["api", "users", "me"] }
          }
        },
        {
          "name": "Get All Users (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "Suspend User (admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/users/{{userId}}/suspend",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "{{userId}}", "suspend"]
            }
          }
        }
      ]
    },
    {
      "name": "Event",
      "item": [
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/events", "host": ["{{baseUrl}}"], "path": ["api", "events"] }
          }
        },
        {
          "name": "Get Nearby Events",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/events/nearby?lat=32.0853&lng=34.7818&radius=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "events", "nearby"],
              "query": [
                { "key": "lat", "value": "32.0853" },
                { "key": "lng", "value": "34.7818" },
                { "key": "radius", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Event By Id",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"] }
          }
        },
        {
          "name": "Create Event",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.data && data.data._id) { pm.collectionVariables.set(\"eventId\", data.data._id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Board Game Night\",\n  \"category\": \"Gaming\",\n  \"startTime\": \"2026-07-01T18:00:00.000Z\",\n  \"endTime\": \"2026-07-01T21:00:00.000Z\",\n  \"location\": { \"lat\": 32.0853, \"lng\": 34.7818 },\n  \"capacity\": 6\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/events", "host": ["{{baseUrl}}"], "path": ["api", "events"] }
          }
        },
        {
          "name": "Update Event (host only)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"capacity\": 8\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/api/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"] }
          }
        },
        {
          "name": "Delete Event (host/admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/events/{{eventId}}", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}"] }
          }
        },
        {
          "name": "Join Event",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/events/{{eventId}}/join", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}", "join"] }
          }
        },
        {
          "name": "Leave Event",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/events/{{eventId}}/join", "host": ["{{baseUrl}}"], "path": ["api", "events", "{{eventId}}", "join"] }
          }
        },
        {
          "name": "Export Event to Calendar",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/events/{{eventId}}/calendar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "events", "{{eventId}}", "calendar"]
            }
          }
        }
      ]
    },
    {
      "name": "Report",
      "item": [
        {
          "name": "Create Report",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data._id) { pm.collectionVariables.set(\"reportId\", data._id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"This event location seems fake\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/events/{{eventId}}/report",
              "host": ["{{baseUrl}}"],
              "path": ["api", "events", "{{eventId}}", "report"]
            }
          }
        },
        {
          "name": "Get Admin Reports (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/reports", "host": ["{{baseUrl}}"], "path": ["api", "reports"] }
          }
        },
        {
          "name": "Resolve Report (admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/reports/{{reportId}}/resolve",
              "host": ["{{baseUrl}}"],
              "path": ["api", "reports", "{{reportId}}", "resolve"]
            }
          }
        }
      ]
    },
    {
      "name": "Feedback",
      "item": [
        {
          "name": "Submit Feedback",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rating\": 5,\n  \"comment\": \"Had a great time!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/events/{{eventId}}/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["api", "events", "{{eventId}}", "feedback"]
            }
          }
        },
        {
          "name": "Get Event Feedback",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/events/{{eventId}}/feedback",
              "host": ["{{baseUrl}}"],
              "path": ["api", "events", "{{eventId}}", "feedback"]
            }
          }
        }
      ]
    },
    {
      "name": "Notification",
      "item": [
        {
          "name": "Get My Notifications",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/notifications", "host": ["{{baseUrl}}"], "path": ["api", "notifications"] }
          }
        },
        {
          "name": "Mark Notification Read",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/notifications/{{notificationId}}/read",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notifications", "{{notificationId}}", "read"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get Audit Logs (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/admin/audit", "host": ["{{baseUrl}}"], "path": ["api", "admin", "audit"] }
          }
        }
      ]
    }
  ]
}
